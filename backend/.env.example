# Database Configuration
# Neon Serverless PostgreSQL connection string
# Format: postgresql://user:password@host/database
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/your-database

# Authentication Secret
# IMPORTANT: This MUST match the NEXT_PUBLIC_BETTER_AUTH_SECRET in frontend/.env.local
# Used for JWT token signing and verification
BETTER_AUTH_SECRET=your-secret-key-min-32-characters-long-change-this-in-production

# Application Settings
APP_ENV=development
DEBUG=True

# CORS Settings (frontend URL)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Settings
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7
