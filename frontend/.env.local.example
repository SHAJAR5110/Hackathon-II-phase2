# API Configuration
# Backend API URL (FastAPI server)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Authentication Secret
# IMPORTANT: This MUST match the BETTER_AUTH_SECRET in backend/.env
# Used for JWT token signing and verification
NEXT_PUBLIC_BETTER_AUTH_SECRET=your-secret-key-min-32-characters-long-change-this-in-production

# Application Settings
NEXT_PUBLIC_APP_NAME=Todo App
NEXT_PUBLIC_APP_ENV=development
